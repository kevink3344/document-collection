JWT_SECRET=change-this-to-a-strong-random-secret-in-production
PORT=4000

# Database: this app is cloud-only. Configure either Turso (default) or Azure
# SQL Server below. Local standalone SQLite is not supported — if neither is
# configured, the server starts but API routes return HTTP 503 until fixed.

# Turso SQLite (libsql) connection
TURSO_DATABASE_URL=libsql://data-collection-pro-kevink3344.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=removed-for-security

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Optional SMTP delivery for notification emails and CC recipients
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
